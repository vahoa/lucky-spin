{
  "name": "lucky-spin",
  "version": "1.0.0",
  "description": "幸运抽奖前端",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "dev:test": "vite --mode test",
    "build": "vue-tsc -p tsconfig.app.json --noEmit && vite build --mode production",
    "build:test": "vue-tsc -p tsconfig.app.json --noEmit && vite build --mode test",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "axios": "^1.6.8",
    "@vueuse/core": "^10.9.0",
    "gsap": "^3.12.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/tsconfig": "^0.5.1",
    "typescript": "~5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.6",
    "sass": "^1.72.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "@rushstack/eslint-patch": "^1.8.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "prettier": "^3.2.5",
    "vitest": "^2.1.0",
    "jsdom": "^25.0.0"
  }
}
